# ==========================================
# POSTGRESQL DATABASE
# ==========================================
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=todo_db

# Для локального запуска через Docker database_url автоматически генерируется в конфиге

# ==========================================
# AUTH & SECURITY
# ==========================================
SECRET_KEY=your_super_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# STORAGE: MINIO
# ==========================================
# Для локальной разработки (Docker Profile: local) используются доступы MinIO.

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_REGION_NAME=us-east-1
MINIO_BUCKET_NAME=trello-local-bucket

S3_ENDPOINT_URL=http://minio:9000
